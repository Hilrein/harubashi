# # ── Database ──────────────────────────────────────────────
# DATABASE_URL="file:./dev.db"

# # ── LLM Provider: anthropic | openai | google | proxy | nvidia ────
# HARUBASHI_LLM_PROVIDER=

# # ── Anthropic ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=

# # ── OpenAI ────────────────────────────────────────────────
# OPENAI_API_KEY=

# Google Gemini via OAuth 2.0 (personal account quota, no billing)
# How to obtain GOOGLE_REFRESH_TOKEN:
#   1. https://developers.google.com/oauthplayground/
#   2. ⚙ → Use your own OAuth credentials → paste client_id / client_secret
#   3. Scopes (BOTH required):
#        https://www.googleapis.com/auth/cloud-platform
#        https://www.googleapis.com/auth/generative-language.retriever
#   4. Authorize → Exchange code → copy refresh_token
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_GEMINI_MODEL=

# # ── Proxy (OpenAI-compatible endpoint) ────────────────────
# HARUBASHI_PROXY_BASE_URL=
# HARUBASHI_PROXY_API_KEY=
# HARUBASHI_PROXY_MODEL=

# # ── NVIDIA NIM (build.nvidia.com) ─────────────────────────
# Browse models & get an API key at https://build.nvidia.com
# NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# # ── Command Guard ─────────────────────────────────────────
# HARUBASHI_SAFE_COMMANDS=ls,cat,echo,pwd,whoami,date,head,tail,wc,find,which
# HARUBASHI_COMMAND_TIMEOUT=30000

# # ── Telegram Gateway ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# # ── Analytics (optional) ──────────────────────────────────
# HARUBASHI_ANALYTICS_ENDPOINT=
